FROM python:3.11-slim

WORKDIR /app

RUN pip install --no-cache-dir \
    streamlit==1.50.0 \
    plotly==6.6.0 \
    pandas==2.2.3 \
    requests==2.32.3

COPY demo/streamlit_app.py ./demo/streamlit_app.py
COPY models/model_cards/ ./models/model_cards/

ENV API_URL=https://port-analysis.web.app/api

EXPOSE 8080

CMD ["python", "-m", "streamlit", "run", "demo/streamlit_app.py", \
     "--server.port=8080", "--server.address=0.0.0.0", "--server.headless=true"]
